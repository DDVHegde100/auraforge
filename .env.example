# Web (Vite) — set in Vercel project env
# Leave empty to use /api rewrite (vercel.json → Railway API)
VITE_API_BASE=

# API (Railway/Docker) — set on API host
AURAFORGE_CORS_ORIGINS=https://auraforge.vercel.app,http://localhost:5173
AURAFORGE_SESSION_DIR=/tmp/auraforge-sessions
AURAFORGE_EXPORT_DIR=/tmp/auraforge-exports
AURAFORGE_MAX_UPLOAD_MB=40
PORT=8787
